{{ 'product-timeline.css' | asset_url | stylesheet_tag }}

<section
  class="product-timeline"
  data-product-timeline
  data-autoplay="{{ section.settings.autoplay }}"
  data-autoplay-speed="{{ section.settings.autoplay_speed | times: 1000 }}"
  style="
    --pt-bg: {{ section.settings.background_color | default: '#FFFFFF' }};
    --pt-text: {{ section.settings.text_color | default: '#1A1A1A' }};
    --pt-accent: {{ section.settings.accent_color | default: '#E0322D' }};
  "
>
  <div class="page-width">

    {%- if section.settings.heading != blank -%}
      <h2 class="product-timeline__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="product-timeline__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- liquid
      assign year_blocks = section.blocks | where: 'type', 'year'
      assign first_visible = ''
    -%}

    {%- if year_blocks.size > 0 -%}

      {%- comment -%} ===== TRACK (Year Dots) ===== {%- endcomment -%}
      <nav class="product-timeline__track" role="tablist" aria-label="{{ section.settings.heading | default: 'Product timeline' | escape }}">
        <div class="product-timeline__line" aria-hidden="true">
          <div class="product-timeline__line-progress"></div>
        </div>

        <ul class="product-timeline__points">
          {%- for block in year_blocks -%}
            {%- liquid
              assign is_active = false
              if forloop.first
                assign is_active = true
                assign first_visible = block.id
              endif
            -%}
            <li class="product-timeline__point-wrap" {{ block.shopify_attributes }}>
              <button
                type="button"
                class="product-timeline__point{% if is_active %} is-active{% endif %}"
                id="pt-tab-{{ block.id }}"
                role="tab"
                aria-selected="{{ is_active }}"
                aria-controls="pt-panel-{{ block.id }}"
                data-timeline-trigger
                data-target="{{ block.id }}"
                data-index="{{ forloop.index0 }}"
              >
                <span class="product-timeline__dot"></span>
                <span class="product-timeline__year">{{ block.settings.year | default: '20XX' }}</span>
              </button>
            </li>
          {%- endfor -%}
        </ul>
      </nav>

      {%- comment -%} ===== CONTENT PANELS ===== {%- endcomment -%}
      <div class="product-timeline__panels">
        {%- for block in year_blocks -%}
          {%- assign is_active = false -%}
          {%- if forloop.first -%}{%- assign is_active = true -%}{%- endif -%}

          <div
            class="product-timeline__panel{% if is_active %} is-active{% endif %}"
            id="pt-panel-{{ block.id }}"
            role="tabpanel"
            aria-labelledby="pt-tab-{{ block.id }}"
            data-timeline-panel
            data-target="{{ block.id }}"
            {% unless is_active %}hidden{% endunless %}
            {{ block.shopify_attributes }}
          >
            <div class="product-timeline__media">
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 1200 }}"
                  alt="{{ block.settings.image.alt | default: block.settings.model_name | escape }}"
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                  loading="{% if is_active %}eager{% else %}lazy{% endif %}"
                  class="product-timeline__image"
                >
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'product-timeline__placeholder' }}
              {%- endif -%}
            </div>

            <div class="product-timeline__content">
              <span class="product-timeline__model-year">{{ block.settings.year }}</span>
              <h3 class="product-timeline__model-name">{{ block.settings.model_name }}</h3>

              {%- if block.settings.description != blank -%}
                <div class="product-timeline__description">{{ block.settings.description }}</div>
              {%- endif -%}

              {%- if block.settings.spec_1_label != blank or block.settings.spec_2_label != blank or block.settings.spec_3_label != blank -%}
                <ul class="product-timeline__specs">
                  {%- if block.settings.spec_1_label != blank -%}
                    <li><span>{{ block.settings.spec_1_label }}</span><strong>{{ block.settings.spec_1_value }}</strong></li>
                  {%- endif -%}
                  {%- if block.settings.spec_2_label != blank -%}
                    <li><span>{{ block.settings.spec_2_label }}</span><strong>{{ block.settings.spec_2_value }}</strong></li>
                  {%- endif -%}
                  {%- if block.settings.spec_3_label != blank -%}
                    <li><span>{{ block.settings.spec_3_label }}</span><strong>{{ block.settings.spec_3_value }}</strong></li>
                  {%- endif -%}
                </ul>
              {%- endif -%}

              {%- if block.settings.product != blank -%}
                {%- assign linked_product = block.settings.product -%}
                <div class="product-timeline__price">{{ linked_product.price | money }}</div>
                <a href="{{ linked_product.url }}" class="button product-timeline__cta">
                  {{ block.settings.cta_label | default: 'View Model' }}
                </a>
              {%- elsif block.settings.cta_url != blank -%}
                <a href="{{ block.settings.cta_url }}" class="button product-timeline__cta">
                  {{ block.settings.cta_label | default: 'Learn More' }}
                </a>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>

    {%- else -%}
      <div class="product-timeline__empty">
        {{ 'onboarding_content.svg' | placeholder_svg_tag }}
        <p>Add "Model Year" blocks to build the timeline.</p>
      </div>
    {%- endif -%}

  </div>
</section>

<script src="{{ 'product-timeline.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Product Timeline",
  "tag": "section",
  "class": "section section-product-timeline",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Model Evolution"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Select a year to see how the model evolved over time."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color (active dot, progress line)",
      "default": "#E0322D"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-play timeline",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Auto-play interval (sec)",
      "min": 3,
      "max": 15,
      "step": 1,
      "default": 6,
      "visible_if": "{{ section.settings.autoplay }}"
    }
  ],
  "blocks": [
    {
      "type": "year",
      "name": "Model Year",
      "settings": [
        {
          "type": "text",
          "id": "year",
          "label": "Year",
          "default": "2024",
          "info": "Displayed on the timeline dot, e.g., 2024"
        },
        {
          "type": "text",
          "id": "model_name",
          "label": "Model Name",
          "default": "Model Name"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Model Image"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description / What changed"
        },
        {
          "type": "header",
          "content": "Specifications (up to 3)"
        },
        {
          "type": "text",
          "id": "spec_1_label",
          "label": "Spec 1 - Label",
          "default": "Motor"
        },
        {
          "type": "text",
          "id": "spec_1_value",
          "label": "Spec 1 - Value"
        },
        {
          "type": "text",
          "id": "spec_2_label",
          "label": "Spec 2 - Label",
          "default": "Range"
        },
        {
          "type": "text",
          "id": "spec_2_value",
          "label": "Spec 2 - Value"
        },
        {
          "type": "text",
          "id": "spec_3_label",
          "label": "Spec 3 - Label",
          "default": "Weight"
        },
        {
          "type": "text",
          "id": "spec_3_value",
          "label": "Spec 3 - Value"
        },
        {
          "type": "header",
          "content": "Link / CTA"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Linked Product",
          "info": "If selected, the price and button will link to this product."
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "Or Custom URL",
          "info": "Used if no product is selected above."
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "Button Label",
          "default": "View Model"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Timeline",
      "blocks": [
        { "type": "year", "settings": { "year": "2022", "model_name": "Model 2022" } },
        { "type": "year", "settings": { "year": "2023", "model_name": "Model 2023" } },
        { "type": "year", "settings": { "year": "2024", "model_name": "Model 2024" } },
        { "type": "year", "settings": { "year": "2025", "model_name": "Model 2025" } }
      ]
    }
  ]
}
{% endschema %}