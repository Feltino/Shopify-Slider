{% comment %}
  Shoppable Lookbook (Interactive hotspots on a lifestyle image)
  Designed with vibrant aesthetic, custom styling, Tailwind CSS, and full Shopify customizer block selection support.
{% endcomment %}

<!-- Load Tailwind CSS CDN and Configure Palette -->
<script src="https://cdn.tailwindcss.com" defer></script>
<script>
  window.addEventListener('DOMContentLoaded', () => {
    if (window.tailwind) {
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              lookbookBg: '{{ section.settings.bg_color }}',
              lookbookText: '{{ section.settings.text_color }}',
              pinColor: '{{ section.settings.pin_color }}',
              pinPulse: '{{ section.settings.pin_pulse_color }}',
              pinIcon: '{{ section.settings.pin_icon_color }}',
            }
          }
        }
      };
    }
  });
</script>

{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
  }

  .lookbook-image-container {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  /* Hotspot Pin Animation */
  .lookbook-pin {
    position: absolute;
    transform: translate(-50%, -50%);
    cursor: pointer;
    z-index: 20;
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .lookbook-pin:hover,
  .lookbook-pin.is-active {
    transform: translate(-50%, -50%) scale(1.15);
    z-index: 30;
  }

  .lookbook-pin-pulse {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    animation: lookbook-pulse 2s infinite;
    opacity: 0.75;
    pointer-events: none;
  }

  @keyframes lookbook-pulse {
    0% {
      transform: scale(1);
      opacity: 0.75;
    }
    70% {
      transform: scale(2.4);
      opacity: 0;
    }
    100% {
      transform: scale(2.4);
      opacity: 0;
    }
  }

  /* Tooltip Card styling & placement */
  .lookbook-tooltip {
    position: absolute;
    width: 280px;
    opacity: 0;
    visibility: hidden;
    transform: scale(0.95);
    transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
    z-index: 40;
  }

  .lookbook-pin.is-active .lookbook-tooltip,
  .lookbook-pin:hover .lookbook-tooltip {
    opacity: 1;
    visibility: visible;
    transform: scale(1);
  }

  /* Tooltip Positions */
  .tooltip-top {
    bottom: calc(100% + 12px);
    left: 50%;
    transform: translate(-50%, 8px) scale(0.95);
  }
  .lookbook-pin.is-active .tooltip-top,
  .lookbook-pin:hover .tooltip-top {
    transform: translate(-50%, 0) scale(1);
  }

  .tooltip-bottom {
    top: calc(100% + 12px);
    left: 50%;
    transform: translate(-50%, -8px) scale(0.95);
  }
  .lookbook-pin.is-active .tooltip-bottom,
  .lookbook-pin:hover .tooltip-bottom {
    transform: translate(-50%, 0) scale(1);
  }

  .tooltip-left {
    right: calc(100% + 12px);
    top: 50%;
    transform: translate(8px, -50%) scale(0.95);
  }
  .lookbook-pin.is-active .tooltip-left,
  .lookbook-pin:hover .tooltip-left {
    transform: translate(0, -50%) scale(1);
  }

  .tooltip-right {
    left: calc(100% + 12px);
    top: 50%;
    transform: translate(-8px, -50%) scale(0.95);
  }
  .lookbook-pin.is-active .tooltip-right,
  .lookbook-pin:hover .tooltip-right {
    transform: translate(0, -50%) scale(1);
  }

  /* Smart positioning details to avoid clipping on mobile screen edges */
  @media (max-width: 640px) {
    .lookbook-tooltip {
      position: fixed;
      left: 50% !important;
      bottom: 24px !important;
      top: auto !important;
      right: auto !important;
      transform: translate(-50%, 20px) !important;
      width: calc(100vw - 32px);
      max-width: 340px;
      z-index: 50;
    }
    .lookbook-pin.is-active .lookbook-tooltip {
      transform: translate(-50%, 0) !important;
    }
    .lookbook-pin:hover .lookbook-tooltip {
      /* Disable hover tooltip trigger on mobile, rely on click/active class */
      opacity: 0;
      visibility: hidden;
    }
    .lookbook-pin.is-active:hover .lookbook-tooltip {
      opacity: 1;
      visibility: visible;
    }
  }
{%- endstyle -%}

<section class="py-12 px-4 md:px-8 lg:px-16 overflow-hidden">
  <div class="max-w-6xl mx-auto">
    
    <!-- Header -->
    {%- if section.settings.title != blank or section.settings.subtitle != blank -%}
      <div class="text-center mb-10">
        {%- if section.settings.subtitle != blank -%}
          <span class="text-xs md:text-sm font-bold tracking-widest uppercase opacity-75 block mb-2">
            {{ section.settings.subtitle }}
          </span>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight">
            {{ section.settings.title }}
          </h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <!-- Interactive Lookbook Wrapper -->
    <div class="lookbook-image-container rounded-2xl shadow-xl bg-gray-100 overflow-hidden border border-gray-200">
      
      <!-- Main Lifestyle Image -->
      {%- if section.settings.image != blank -%}
        <img 
          src="{{ section.settings.image | image_url: width: 1500 }}" 
          alt="{{ section.settings.image.alt | default: section.settings.title | escape }}"
          class="w-full h-auto object-cover block"
          loading="lazy"
          width="1500"
          height="1000"
        >
      {%- else -%}
        <div class="w-full aspect-[16/9] bg-slate-200 flex items-center justify-center relative">
          {{ 'lifestyle-1' | placeholder_svg_tag: 'w-full h-full object-cover opacity-60' }}
          <div class="absolute inset-0 flex flex-col items-center justify-center text-slate-700 bg-black/10">
            <svg class="w-12 h-12 mb-2 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <p class="font-semibold text-sm">Please select a lifestyle image in Customizer</p>
          </div>
        </div>
      {%- endif -%}

      <!-- Hotspots Pins Overlay -->
      {%- for block in section.blocks -%}
        {%- assign prod = block.settings.product -%}
        
        <div 
          class="lookbook-pin group"
          id="pin-{{ block.id }}"
          style="left: {{ block.settings.x_pos }}%; top: {{ block.settings.y_pos }}%;"
          data-trigger="{{ section.settings.trigger_type }}"
          {{ block.shopify_attributes }}
        >
          <!-- Pulsing dot outer element -->
          <div 
            class="lookbook-pin-pulse" 
            style="background-color: {{ section.settings.pin_pulse_color }};"
          ></div>

          <!-- Solid pin center dot -->
          <button 
            type="button"
            class="relative w-8 h-8 rounded-full border-2 border-white shadow-lg flex items-center justify-center transition-all duration-300 transform group-hover:scale-110 focus:outline-none"
            style="background-color: {{ section.settings.pin_color }}; color: {{ section.settings.pin_icon_color }};"
            aria-label="View product details"
          >
            <!-- Pin Center Icon -->
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
          </button>

          <!-- Tooltip Product Card -->
          <div class="lookbook-tooltip tooltip-{{ block.settings.card_position }} bg-white/95 backdrop-blur-md border border-gray-100 rounded-xl p-3 shadow-2xl pointer-events-auto text-left flex items-start gap-3">
            
            <!-- Close Button for Touch Devices -->
            <button 
              type="button"
              class="absolute top-2 right-2 text-gray-400 hover:text-gray-600 sm:hidden focus:outline-none close-tooltip-btn"
              aria-label="Close details"
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>

            {%- if prod != blank -%}
              <!-- Product Image -->
              <div class="w-16 h-16 rounded-lg bg-gray-50 overflow-hidden flex-shrink-0">
                {%- if prod.featured_media != blank -%}
                  <img 
                    src="{{ prod.featured_media | image_url: width: 120 }}" 
                    alt="{{ prod.featured_media.alt | escape }}" 
                    class="w-full h-full object-cover"
                    loading="lazy"
                    width="120"
                    height="120"
                  >
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'w-full h-full object-cover bg-gray-100' }}
                {%- endif -%}
              </div>

              <!-- Product Info -->
              <div class="flex-grow min-w-0">
                <h4 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-0.5 truncate">{{ prod.vendor }}</h4>
                <h3 class="text-sm font-bold text-gray-900 truncate leading-snug mb-1 hover:underline">
                  <a href="{{ prod.url }}">{{ prod.title }}</a>
                </h3>

                <!-- Price Block -->
                <div class="flex items-center gap-1.5 mb-2">
                  <span class="text-sm font-extrabold text-rose-600">{{ prod.price | money }}</span>
                  {%- if prod.compare_at_price > prod.price -%}
                    <span class="text-xs text-gray-400 line-through">{{ prod.compare_at_price | money }}</span>
                  {%- endif -%}
                </div>

                <!-- Action Button -->
                <a 
                  href="{{ prod.url }}" 
                  class="inline-flex items-center justify-center gap-1 text-xs font-extrabold px-3 py-1.5 rounded-lg w-full bg-slate-900 text-white hover:bg-slate-800 transition-colors"
                >
                  <span>Shop Now</span>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3 h-3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                  </svg>
                </a>
              </div>
            {%- else -%}
              <!-- Placeholder Product Card in Customizer -->
              <div class="w-16 h-16 rounded-lg bg-gray-100 flex-shrink-0 flex items-center justify-center">
                {{ 'product-1' | placeholder_svg_tag: 'w-full h-full object-cover' }}
              </div>
              <div class="flex-grow min-w-0">
                <h4 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-0.5">Demo Brand</h4>
                <h3 class="text-sm font-bold text-gray-900 truncate mb-1">Example Product</h3>
                <div class="flex items-center gap-1.5 mb-2">
                  <span class="text-sm font-extrabold text-rose-600">$49.00</span>
                </div>
                <button 
                  type="button"
                  class="inline-flex items-center justify-center gap-1 text-xs font-extrabold px-3 py-1.5 rounded-lg w-full bg-slate-900 text-white"
                >
                  <span>View Details</span>
                </button>
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}

    </div>
  </div>
</section>

<script>
  (function() {
    function initLookbook(section) {
      if (!section) return;
      const pins = section.querySelectorAll('.lookbook-pin');
      
      pins.forEach(pin => {
        const trigger = pin.getAttribute('data-trigger') || 'click';
        const button = pin.querySelector('button');
        const closeBtn = pin.querySelector('.close-tooltip-btn');

        // Toggle active status helper
        function togglePin(e) {
          e.stopPropagation();
          const isActive = pin.classList.contains('is-active');
          // Close all other active pins first
          pins.forEach(p => p.classList.remove('is-active'));
          
          if (!isActive) {
            pin.classList.add('is-active');
          }
        }

        // Close details helper
        function closePin(e) {
          e.stopPropagation();
          pin.classList.remove('is-active');
        }

        if (trigger === 'click') {
          button.addEventListener('click', togglePin);
        } else {
          // Hover setup (primarily desktop)
          // Still register click for mobile fallback
          button.addEventListener('click', togglePin);
          
          pin.addEventListener('mouseenter', () => {
            // Only add hover effects on non-touch screens
            if (window.matchMedia('(hover: hover)').matches) {
              pins.forEach(p => p.classList.remove('is-active'));
              pin.classList.add('is-active');
            }
          });
          
          pin.addEventListener('mouseleave', () => {
            if (window.matchMedia('(hover: hover)').matches) {
              pin.classList.remove('is-active');
            }
          });
        }

        // Close on close button click
        if (closeBtn) {
          closeBtn.addEventListener('click', closePin);
        }
      });

      // Global click listener to dismiss active tooltips when clicking outside
      function handleOutsideClick(e) {
        if (!e.target.closest('.lookbook-pin')) {
          pins.forEach(p => p.classList.remove('is-active'));
        }
      }
      document.addEventListener('click', handleOutsideClick);

      // Clean up event listener when section unloads
      section.addEventListener('lookbook:destroy', () => {
        document.removeEventListener('click', handleOutsideClick);
      });
    }

    // Initialize logic on page load
    function checkAndInit() {
      const sectionId = 'shopify-section-{{ section.id }}';
      const sectionContainer = document.getElementById(sectionId);
      if (sectionContainer) {
        initLookbook(sectionContainer);
      }
    }

    document.addEventListener('DOMContentLoaded', checkAndInit);

    // Shopify Customizer / Design Mode Integrations
    document.addEventListener('shopify:section:load', (event) => {
      if (event.detail.sectionId === '{{ section.id }}') {
        const sectionContainer = document.getElementById('shopify-section-' + event.detail.sectionId);
        if (sectionContainer) {
          initLookbook(sectionContainer);
        }
      }
    });

    document.addEventListener('shopify:section:unload', (event) => {
      if (event.detail.sectionId === '{{ section.id }}') {
        const sectionContainer = document.getElementById('shopify-section-' + event.detail.sectionId);
        if (sectionContainer) {
          sectionContainer.dispatchEvent(new CustomEvent('lookbook:destroy'));
        }
      }
    });

    // When a merchant selects a specific block (hotspot) in customizer, open its tooltip
    document.addEventListener('shopify:block:select', (event) => {
      if (event.detail.sectionId === '{{ section.id }}') {
        const blockId = event.detail.blockId;
        const targetPin = document.getElementById('pin-' + blockId);
        if (targetPin) {
          // Remove active state from other pins
          const sectionContainer = document.getElementById('shopify-section-{{ section.id }}');
          if (sectionContainer) {
            sectionContainer.querySelectorAll('.lookbook-pin').forEach(p => p.classList.remove('is-active'));
          }
          // Activate this pin
          targetPin.classList.add('is-active');
          // Smooth scroll to pin on mobile if needed
          targetPin.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      }
    });

    // When deselecting the block, close tooltip
    document.addEventListener('shopify:block:deselect', (event) => {
      if (event.detail.sectionId === '{{ section.id }}') {
        const blockId = event.detail.blockId;
        const targetPin = document.getElementById('pin-' + blockId);
        if (targetPin) {
          targetPin.classList.remove('is-active');
        }
      }
    });

  })();
</script>

{% schema %}
{
  "name": "Shoppable Lookbook",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Shop the Style"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "INTERACTIVE LOOKBOOK"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Lifestyle Photo"
    },
    {
      "type": "select",
      "id": "trigger_type",
      "label": "Hotspot Interaction",
      "options": [
        {
          "value": "click",
          "label": "Click to Open"
        },
        {
          "value": "hover",
          "label": "Hover / Click"
        }
      ],
      "default": "click"
    },
    {
      "type": "header",
      "content": "Color Schemes"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f9fafb"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#111827"
    },
    {
      "type": "color",
      "id": "pin_color",
      "label": "Pin Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "pin_pulse_color",
      "label": "Pin Pulse Color",
      "default": "rgba(0, 0, 0, 0.4)"
    },
    {
      "type": "color",
      "id": "pin_icon_color",
      "label": "Pin Icon/Plus Color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "hotspot",
      "name": "Product Hotspot",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        },
        {
          "type": "range",
          "id": "x_pos",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Horizontal Position (X)",
          "default": 50
        },
        {
          "type": "range",
          "id": "y_pos",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Vertical Position (Y)",
          "default": 50
        },
        {
          "type": "select",
          "id": "card_position",
          "label": "Card Position (Desktop)",
          "options": [
            {
              "value": "top",
              "label": "Top"
            },
            {
              "value": "bottom",
              "label": "Bottom"
            },
            {
              "value": "left",
              "label": "Left"
            },
            {
              "value": "right",
              "label": "Right"
            }
          ],
          "default": "top"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shoppable Lookbook",
      "blocks": [
        {
          "type": "hotspot",
          "settings": {
            "x_pos": 35,
            "y_pos": 40,
            "card_position": "bottom"
          }
        },
        {
          "type": "hotspot",
          "settings": {
            "x_pos": 65,
            "y_pos": 55,
            "card_position": "top"
          }
        }
      ]
    }
  ]
}
{% endschema %}
